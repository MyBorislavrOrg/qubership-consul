{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": ["**/.github/workflows/**"],
      "schedule": ["every weekend"],
      "pinDigests": true
    },
    {
      "matchManagers": ["gomod"],
      "matchFileNames": [
        "disaster-recovery/go.mod",
        "acl-configurator/rest-acl-configurator/go.mod",
        "acl-configurator/consul-acl-configurator-operator/go.mod"
      ],
      "schedule": ["every weekend"]
    },
    {
      "matchManagers": ["dockerfile"],
      "matchFileNames": [
        "docker-transfer/**/Dockerfile",
        "backup-daemon/docker/**/Dockerfile",
        "disaster-recovery/docker/**/Dockerfile",
        "integration-tests/docker/**/Dockerfile",
        "acl-configurator/sdk-tool/**/Dockerfile",
        "acl-configurator/rest-acl-configurator/**/Dockerfile",
        "acl-configurator/consul-acl-configurator-operator/**/Dockerfile",
        "remove-tokens/docker/**/Dockerfile"
      ],
      "schedule": ["every weekend"]
    },
    {
      "matchManagers": ["pip"],
      "matchFileNames": [
        "backup-daemon/docker/**/requirements*.txt",
        "backup-daemon/docker/**/setup.py",
        "backup-daemon/docker/**/pyproject.toml",
        "integration-tests/docker/**/requirements*.txt",
        "integration-tests/docker/**/setup.py",
        "integration-tests/docker/**/pyproject.toml"
      ],
      "schedule": ["every weekend"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".github/workflows/*"],
      "matchStrings": [
         "datasource=(?<datasource>.*?) depName=(?<depName>.*?) versioning=(?<versioning>.*?)\\n.*?pipeline_branch: '(?<currentValue>.*)'"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}digest{{/if}}"
    }
  ]
}
