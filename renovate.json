{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "packageRules": [
    // GitHub Actions
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": ["**/.github/workflows/**"],
      "schedule": ["every weekend"]
    },

    // Go modules (gomod)
    {
      "matchManagers": ["gomod"],
      "matchFileNames": [
        "disaster-recovery/go.mod",
        "acl-configurator/rest-acl-configurator/go.mod",
        "acl-configurator/consul-acl-configurator-operator/go.mod"
      ],
      "schedule": ["every weekend"]
    },

    // Docker (Dockerfiles)
    {
      "matchManagers": ["dockerfile"],
      "matchFileNames": [
        "docker-transfer/**/Dockerfile",
        "backup-daemon/docker/**/Dockerfile",
        "disaster-recovery/docker/**/Dockerfile",
        "integration-tests/docker/**/Dockerfile",
        "acl-configurator/sdk-tool/**/Dockerfile",
        "acl-configurator/rest-acl-configurator/**/Dockerfile",
        "acl-configurator/consul-acl-configurator-operator/**/Dockerfile",
        "remove-tokens/docker/**/Dockerfile"
      ],
      "schedule": ["every weekend"]
    },

    // Python (pip / requirements.txt и т.п.)
    {
      "matchManagers": ["pip"],
      "matchFileNames": [
        "backup-daemon/docker/**/requirements*.txt",
        "backup-daemon/docker/**/setup.py",
        "backup-daemon/docker/**/pyproject.toml",
        "integration-tests/docker/**/requirements*.txt",
        "integration-tests/docker/**/setup.py",
        "integration-tests/docker/**/pyproject.toml"
      ],
      "schedule": ["every weekend"]
    },
    {
      "matchPackageNames": ["Netcracker/qubership-test-pipelines"],
      "matchManagers": ["regex"],
      "commitMessageTopic": "consul workflow",
      "branchTopic": "renovate/consul-workflow-{{newValue}}",
      "automerge": false
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["\\.ya?ml$"],
      "matchStrings": [
        "pipeline_branch: '(?<currentValue>[a-f0-9]+)'"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "Netcracker/qubership-test-pipelines",
      "versioningTemplate": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "autoReplaceStringTemplate": "pipeline_branch: '{{#if newDigest}}{{newDigest}}{{else}}{{newValue}}{{/if}}'"
    }
  ]
}
